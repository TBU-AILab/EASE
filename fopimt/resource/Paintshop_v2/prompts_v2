import numpy as np

def run(objective_function, dim, x_bound_min, x_bound_max, y_bound_min, y_bound_max, max_evals, x_init, y_init):
    best_cf = float('inf')
    x_best = list()
    y_best = list()

    # Algorithm body
    for eval in range(max_evals):
        x_params = np.array([np.random.uniform(x_bound_min, x_bound_max) for _ in range(dim)])
        y_params = np.array([np.random.uniform(y_bound_min, y_bound_max) for _ in range(dim)])
        fitness = objective_function(x_params, y_params)
        if best_cf is None or fitness <= best_cf:
            best_cf = fitness

    return best_cf